
#PROGRAM 13 Combine multiple arrays row-wise.
# Create two arrays
arr1 <- array(1:6, dim = c(2,3))
arr2 <- array(7:12, dim = c(2,3))

print("Array 1")
print(arr1)

print("Array 2")
print(arr2)

# Combine arrays row-wise
combined_array <- rbind(arr1, arr2)

print("Combined Array (Row-wise)")
print(combined_array)
